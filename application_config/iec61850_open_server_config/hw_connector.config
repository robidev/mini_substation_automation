BUS2LD1/B2TVTR2 = 16 # generate sine-90, based on index2
BUS2LD1/B2TVTR3 = 17 # generate sine-180, based on index3


[TR1]
socket=/tmp/api_sock5

# SWI-Refs: (routing events, and sending operates)
#REf : IO-index
TR1LD1/XCBR1 = 12
TR1LD1/XSWI2 = 6
TR1LD1/XSWI3 = 7

# TR-refs: (subscribe to transformer-data)
# Ref : DATA-index
TR1LD1/TCTR1 = 6 # generate sine-0, based on index1
TR1LD1/TCTR2 = 7 # generate sine-90, based on index2
TR1LD1/TCTR3 = 8 # generate sine-180, based on index3

TR1LD1/B1TVTR1 = 12 # generate sine-0, based on index1
TR1LD1/B1TVTR2 = 13 # generate sine-90, based on index2
TR1LD1/B1TVTR3 = 14 # generate sine-180, based on index3TR

