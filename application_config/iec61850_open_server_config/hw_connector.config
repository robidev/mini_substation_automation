TR2LD1/XSWI2 = 8
TR2LD1/XSWI3 = 9

# TR-refs: (subscribe to transformer-data)
# Ref : DATA-index
TR2LD1/TCTR1 = 9 # generate sine-0, based on index1
TR2LD1/TCTR2 = 10 # generate sine-90, based on index2
TR2LD1/TCTR3 = 11 # generate sine-180, based on index3

