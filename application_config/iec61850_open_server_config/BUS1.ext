ER(null FEED2LD1/XSWI3.Pos.stVal PDIF_in_swi_1 GOOSE FEED2LD1/LLN0.Feed2SwiPosCtl);
ER(null TR1LD1/XSWI2.Pos.stVal PDIF_out_swi_0 GOOSE TR1LD1/LLN0.Trafo1SwiPosCtl);
ER(null TR2LD1/XSWI2.Pos.stVal PDIF_out_swi_1 GOOSE TR2LD1/LLN0.Trafo2SwiPosCtl);
