LN(PTRC1){
CL(PTRC);
IN{
ER(PDIF_trip BUS1LD1/PDIF1.Op.general Op1 Poll BUS1/);
ER(CILO_EnaOpn BUS1LD1/CILO1.EnaOpn.stVal EnaOpn Poll BUS1/);
