m_ctr4_phsA       = BUS1LD1/MMXU4, A.phsA.cVal.mag.f
m_ctr4_phsB       = BUS1LD1/MMXU4, A.phsB.cVal.mag.f
m_ctr4_phsC       = BUS1LD1/MMXU4, A.phsC.cVal.mag.f

m_v1_pA           = BUS1LD1/MMXU5, PhV.phsA.cVal.mag.f
m_v1_pB           = BUS1LD1/MMXU5, PhV.phsB.cVal.mag.f
m_v1_pC           = BUS1LD1/MMXU5, PhV.phsC.cVal.mag.f

