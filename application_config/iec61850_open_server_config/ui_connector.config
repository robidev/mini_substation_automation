s_swi4_blkcls        = FEED2LD1/XSWI4, BlkCls.stVal

m_ctr1_phsA       = FEED2LD1/MMXU1, A.phsA.cVal.mag.f
m_ctr1_phsB       = FEED2LD1/MMXU1, A.phsB.cVal.mag.f
m_ctr1_phsC       = FEED2LD1/MMXU1, A.phsC.cVal.mag.f
m_ctr1_phsAngA    = FEED2LD1/MMXU1, A.phsA.cVal.ang.f
