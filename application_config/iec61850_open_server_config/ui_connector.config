m_v1_pC         = FEED2LD1/MMXU2, PhV.phsC.cVal.mag.f
m_v1_aA         = FEED2LD1/MMXU2, PhV.phsA.cVal.ang.f
m_v1_aB         = FEED2LD1/MMXU2, PhV.phsB.cVal.ang.f
m_v1_aC         = FEED2LD1/MMXU2, PhV.phsC.cVal.ang.f

m_v2_pA         = FEED2LD1/MMXU3, PhV.phsA.cVal.mag.f
m_v2_pB         = FEED2LD1/MMXU3, PhV.phsB.cVal.mag.f
m_v2_pC         = FEED2LD1/MMXU3, PhV.phsC.cVal.mag.f
m_v2_aA         = FEED2LD1/MMXU3, PhV.phsA.cVal.ang.f
m_v2_aB         = FEED2LD1/MMXU3, PhV.phsB.cVal.ang.f
m_v2_aC         = FEED2LD1/MMXU3, PhV.phsC.cVal.ang.f


[BUS1] # third ied
socket=/run/iec61850_ui/iec61850_relay_3.sock
# Measurements
ctr1                = BUS1LD1/MMXU1
ctr2                = BUS1LD1/MMXU2
ctr3                = BUS1LD1/MMXU3
ctr4                = BUS1LD1/MMXU4
