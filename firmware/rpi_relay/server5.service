# /etc/systemd/system/server5.service
[Unit]
Description=C++ server 5
After=network.target

[Service]
Type=simple
User=root
Group=root

WorkingDirectory=/opt/iec61850_open_server

ExecStart=/opt/iec61850_open_server/open_server \
		-e eth0 \
		-i 172.16.1.40 \
		-p 102 \
		-c cfg/TR1.cfg \
		-x cfg/TR1.ext \
		-t L

Restart=on-failure
RestartSec=5
StartLimitIntervalSec=60
StartLimitBurst=3

StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
